# Copy this file to .env and fill in your actual values for cPanel deployment

# Environment Configuration
DJANGO_ENVIRONMENT=production
DEBUG=False

# Security
SECRET_KEY=your-super-secure-secret-key-change-this-for-production

# Your Domain (cPanel hosting)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# MySQL Database Configuration (from cPanel)
MYSQL_DB=your_cpanel_database_name
MYSQL_USER=your_cpanel_database_user
MYSQL_PASSWORD=your_cpanel_database_password
MYSQL_HOST=localhost
MYSQL_PORT=3306

# API Keys
GEMINI_API_KEY=your-gemini-api-key-here

# Email Configuration (cPanel email)
EMAIL_HOST=mail.yourdomain.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@yourdomain.com
EMAIL_HOST_PASSWORD=your-email-password

# Optional: Default from email
DEFAULT_FROM_EMAIL=your-email@yourdomain.com
