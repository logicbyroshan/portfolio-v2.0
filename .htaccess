RewriteEngine On
RewriteBase /

# Handle static files directly
RewriteRule ^static/(.*)$ portfolio-2.0/static/$1 [L]
RewriteRule ^media/(.*)$ portfolio-2.0/media/$1 [L]

# Handle all other requests with Django
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ passenger_wsgi.py [L]

# Security headers
Header always set X-Frame-Options DENY
Header always set X-Content-Type-Options nosniff
Header always set X-XSS-Protection "1; mode=block"

# Deny access to sensitive files
<FilesMatch "\.(env|py|pyc|pyo|log|ini|conf)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Deny access to Django admin media for security
<Files "passenger_wsgi.py">
    Order allow,deny
    Allow from all
</Files>
